{
  "name": "json-myers-monorepo",
  "version": "0.0.0",
  "description": "JSON diff/patch — Myers algorithm with identity-aware semantics. Monorepo housing json-myers (v3, current) and the legacy v2 implementation under old/.",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --recursive --filter='json-myers' build",
    "dev": "pnpm --parallel --recursive --filter='json-myers' dev",
    "test": "pnpm --recursive --filter='json-myers' test",
    "test:coverage": "pnpm --recursive --filter='json-myers' test:coverage",
    "typecheck": "pnpm --recursive --filter='json-myers' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .prettierignore",
    "clean": "pnpm --recursive --filter='json-myers' clean",
    "changeset": "changeset",
    "changeset status": "changeset status",
    "changeset version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "@vitest/coverage-v8": "^4.0.13",
    "@vitest/ui": "^4.0.13",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vitest": "^4.0.13"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "author": {
    "name": "Anderson D. Rosa",
    "email": "andersondrosa@outlook.com",
    "url": "https://github.com/andersondrosa"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/andersondrosa/json-myers.git"
  },
  "homepage": "https://github.com/andersondrosa/json-myers#readme",
  "bugs": {
    "url": "https://github.com/andersondrosa/json-myers/issues"
  },
  "license": "MIT"
}
