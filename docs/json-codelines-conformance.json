{
  "name": "json-myers codelines conformance",
  "version": "1.0.0",
  "description": "Validates json-myers behavior on arrays of code lines — analogous to git diff over text files. Each case is a (before, after) pair of line arrays, with the git diff op count captured from a real `git diff --no-index` run for reference. The suite checks: (1) diffJson stability across runs, (2) forward/backward round-trip, (3) raw Myers op count matches git's (both implement minimal edit script), (4) convertJsonMyersToGitDiff produces a valid unified-diff structure.",
  "spec": {
    "rules": [
      "RD1 — `diffJson(before, after)` is bit-stable across N runs.",
      "RD2 — `patchJson(before, diffJson(before, after)) === after`.",
      "RD3 — `patchJson(after, diffJson(after, before)) === before`.",
      "RC1 — Raw Myers op count (without move detection) equals git's add+remove total. Both algorithms minimize edit script length.",
      "RC2 — `convertJsonMyersToGitDiff` output contains valid unified-diff structure (header, hunks, +/- lines)."
    ],
    "runner_protocol": {
      "default_runs": 5,
      "git_comparison": "Counts of raw add/remove ops must match git's add/remove line counts."
    }
  },
  "cases": [
    {
      "id": "add-import",
      "description": "Adding a named import — single line swap",
      "before": [
        "import { readFile } from \"fs/promises\";",
        "import { join } from \"path\";",
        "",
        "const CONFIG_PATH = \"./config.json\";",
        "",
        "interface Config {",
        "  port: number;",
        "  host: string;",
        "  debug: boolean;",
        "}",
        "",
        "async function loadConfig(): Promise<Config> {",
        "  const raw = await readFile(CONFIG_PATH, \"utf-8\");",
        "  return JSON.parse(raw);",
        "}",
        "",
        "function validatePort(port: number): boolean {",
        "  if (port < 1) return false;",
        "  if (port > 65535) return false;",
        "  return true;",
        "}",
        "",
        "async function main() {",
        "  const config = await loadConfig();",
        "  if (!validatePort(config.port)) {",
        "    throw new Error(\"Invalid port\");",
        "  }",
        "  console.log(`Starting on ${config.host}:${config.port}`);",
        "}",
        "",
        "main().catch(console.error);"
      ],
      "after": [
